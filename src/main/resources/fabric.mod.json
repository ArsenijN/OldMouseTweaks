  "authors": [
    "ArsenijN"
  ],
  "contact": {
    "sources": "https://github.com/ArsenijN/OldMouseTweaks"
  },
  "license": "MIT",
  "icon": "assets/old-mouse-tweaks/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": ["com.arsenius_gen.OldMouseTweaks"],
    "client": ["com.arsenius_gen.OldMouseTweaksClient"],
    "modmenu": ["com.arsenius_gen.ModMenuIntegration"]
  },
  "mixins": [
    {
      "config": "old-mouse-tweaks.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.15.0",
